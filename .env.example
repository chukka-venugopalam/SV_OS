# =============================================================================
# SV-OS — Root Environment Configuration Reference
# =============================================================================
# This file documents all environment variables used across the monorepo.
# Copy the relevant values to the app-specific .env.local files.
# =============================================================================
#
# ── Web App — apps/web/.env.local ───────────────────────────────────
#
# NEXT_PUBLIC_API_URL          http://localhost:8000
# NEXT_PUBLIC_SUPABASE_URL     https://your-project.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY eyJhbGciOiJIUzI1NiIs...
# NEXT_PUBLIC_APP_URL          (optional) https://sv-os.com
#
# ── API — apps/api/.env ────────────────────────────────────────────
#
# DATABASE_URL            postgresql+asyncpg://svos:password@localhost:5432/svos
# SUPABASE_URL            https://your-project.supabase.co
# SUPABASE_SERVICE_KEY    your-service-role-key
# SECRET_KEY              your-secret-key-at-least-32-chars
# ENVIRONMENT             development
# LOG_LEVEL               INFO
# CORS_ORIGINS            http://localhost:3000
# API_RATE_LIMIT          100
